{
  "name": "buildwithnexus",
  "version": "0.12.2",
  "description": "Fast, local-first AI coding agent for the terminal, written in Rust. Works with hosted APIs (Anthropic, OpenAI) and local models (Ollama).",
  "main": "index.js",
  "bin": {
    "buildwithnexus": "bin/buildwithnexus.js",
    "bwn": "bin/buildwithnexus.js"
  },
  "files": [
    "index.js",
    "index.browser.js",
    "bin/buildwithnexus.js",
    "scripts/resolve-binary.js",
    "scripts/bootstrap.js",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "harness/Cargo.toml"
  ],
  "scripts": {
    "build": "cargo build --release --manifest-path harness/Cargo.toml",
    "start": "node bin/buildwithnexus.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "rust",
    "tui",
    "anthropic",
    "openai",
    "ollama",
    "local-llm",
    "multimodal",
    "ffmpeg",
    "terminal-ui",
    "claude",
    "developer-tools"
  ],
  "author": "Garrett Eaglin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Garretts-Apps/buildwithnexus.git"
  },
  "bugs": {
    "url": "https://github.com/Garretts-Apps/buildwithnexus/issues"
  },
  "homepage": "https://buildwithnexus.dev",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "optionalDependencies": {
    "buildwithnexus-linux-x64": "0.12.2",
    "buildwithnexus-linux-arm64": "0.12.2",
    "buildwithnexus-darwin-x64": "0.12.2",
    "buildwithnexus-darwin-arm64": "0.12.2",
    "buildwithnexus-win32-x64": "0.12.2"
  },
  "browser": "./index.browser.js"
}
